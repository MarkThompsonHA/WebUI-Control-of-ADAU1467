{
  "files.associations": {
    "*.h": "cpp",
    "*.ino": "cpp"
  },
  "editor.tabSize": 2,
  "editor.formatOnSave": false,
  "C_Cpp.default.compilerPath": "",
  "C_Cpp.errorSquiggles": "disabled",
  "files.exclude": {
    "**/.git": true,
    "**/.svn": true,
    "**/.DS_Store": true,
    "**/node_modules": true,
    "**/.pio": true
  },
  "search.exclude": {
    "**/.pio": true
  }
}
